---
import Header from './Header.astro';
import ScrapsView from './ScrapsView.astro';
import Footer from './Footer.astro';

const { scrapCount = 0, initialSlug } = Astro.props;
---

<Header hero={true} scrapCount={scrapCount} />
<ScrapsView initialSlug={initialSlug} />
<Footer />

<script>
	import '../scripts/scrolling.js';
	import '../scripts/textgrow.js';
	import '../scripts/teranoptise.js';
</script>