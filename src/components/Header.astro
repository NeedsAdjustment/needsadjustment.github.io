---

const { scrapCount = 0, hero = false, scrolled = false } = Astro.props

---

<header class:list={{ hero, scrolled }}>
  <h1>Joshua Soong</h1>
  <h2>
    <tera class="category" id="leftCreature"></tera>
    <a class="category" data-count-key="coding" href='https://github.com/NeedsAdjustment'>coding<num>0</num></a>
    <a class="category" data-scraps href="/scraps/">scraps<num>{scrapCount}</num></a>
    <a class="category" data-snaps href="/snaps/">snaps<num>0</num></a>
    <a class="category" data-count-key="design" href='https://dribbble.com/NeedsAdjustment'>design<num>0</num></a>
    <tera class="category" id="rightCreature"></tera>
  </h2>
  <div class="scroll-indicator">
    <i class="arrow1 ph-bold ph-caret-down"></i>
    <i class="arrow2 ph-bold ph-caret-down"></i>
  </div>
</header>

{/* Count fetching + re-application lives in route.js so the numbers survive
    ClientRouter navigations even if the header isn't persisted. */}

<style>
  header {
    position: fixed;
    top: 0;
    width: 100%;
    max-width: 1200px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    -webkit-user-select: none;
    user-select: none;
    transition: transform 0.4s ease;
    gap: clamp(0.1rem, 0.5rem, 20px);
  }

  header.hero {
    top: 50%;
    transform: translateY(-50%);
  }

  header.hero.scrolled {
    transform: translateY(-50vh);
  }

  header:not(.hero) h1,
  header:not(.hero) .scroll-indicator {
    display: none;
  }

  h1 {
    cursor: default;
    font-family: 'Unbounded';
    font-size: clamp(1rem, 10vw, 7.4rem);
    margin: 0;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    max-height: 20rem;
    transition: opacity 0.4s ease, max-height 0.4s ease, margin 0.4s ease, padding 0.4s ease;
  }

  header.hero.scrolled h1 {
    opacity: 0;
    max-height: 0;
    margin: 0;
    padding: 0;
  }

  header.hero.scrolled .scroll-indicator {
    display: none;
  }

  tera {
    user-select: none;
    font-family: 'Teranoptia';
    font-size: 1.5em;
  }

  h2 {
    font-size: clamp(1rem, 2vw, 1.5rem);
    font-weight: 400;
    margin: 0;
    width: 100%;
    display: flex;
    justify-content: space-around;
    align-items: center;
    transition: padding-top 0.4s ease;
  }

  header.hero.scrolled h2 {
    padding-top: 1rem;
  }

  header[data-measuring],
  header[data-measuring] * {
    transition: none !important;
  }

  h2 a.category {
    cursor: pointer;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--ui-border);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--secondary-background) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    color: inherit;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  h2 a.category:hover {
    background: color-mix(in srgb, var(--secondary-background) 70%, transparent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  }

  h2 a.category.active {
    background: var(--link-colour);
    border-color: var(--link-colour);
    color: var(--background-color);
  }
  h2 a.category.active num {
    color: var(--background-color);
    font-feature-settings: 'ss04';
  }

  num {
    font-family: 'Unbounded';
    font-weight: 400;
    font-size: 0.8em;
    vertical-align: sub;
    font-feature-settings: 'ss02';
    text-decoration: none;
    color: inherit;
    transition: color 0.5s ease;
  }

  h2 a:hover num {
    color: var(--link-colour);
    font-feature-settings: 'ss04';
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 1em;
    padding: var(--space-sm);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--text-color);
  }

  .arrow1 {
    margin-bottom: -0.3em;
    animation: fade-in-out 3s ease-out infinite;
  }

  .arrow2 {
    margin-top: -0.3em;
    animation: fade-in-out 3s ease-out infinite 0.5s;
  }

  @keyframes fade-in-out {
    0%, 100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }

</style>
