<header>
  <h1>Joshua Soong</h1>
  <h2>
    <tera class="category" id="leftCreature"></tera>
    <a class="category">design<num>0</num></a>
    <a class="category" href='https://github.com/NeedsAdjustment'>coding<num>0</num></a>
    <a class="category">prose<num>0</num></a>
    <a class="category">music<num>0</num></a>
    <tera class="category" id="rightCreature"></tera>
  </h2>
  <div class="scroll-indicator">
    <i class="arrow1 ph-bold ph-caret-down"></i>
    <i class="arrow2 ph-bold ph-caret-down"></i>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    max-width: 1200px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    -webkit-user-select: none; /* Safari */
    user-select: none;
  }

  h1 {
    cursor: default;
    font-family: 'Unbounded';
    font-size: clamp(1rem, 10vw, 7.4rem);
    margin: 0;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    max-height: 20rem;
    transition: opacity 0.4s ease, max-height 0.4s ease, margin 0.4s ease, padding 0.4s ease;
  }

  tera {
    user-select: none;
    font-family: 'Teranoptia';
    font-size: 1.5em;
  }

  h2 {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 400;
    margin: 0;
    padding-top: 0;
    display: flex;
    width: 99%;
    justify-content: space-around;
    align-items: center;
    transition: padding-top 0.4s ease;
  }

  h2 a.category {
    cursor: pointer;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--ui-border);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--secondary-background) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    color: inherit;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  h2 a.category:hover {
    background: color-mix(in srgb, var(--secondary-background) 70%, transparent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  }

  num {
    font-family: 'Unbounded';
    font-weight: 400;
    font-size: 0.8em;
    vertical-align: sub;
    font-feature-settings: 'ss02';
    text-decoration: none;
    color: inherit;
    transition: color 0.5s ease;
  }

  h2 a:hover num {
    color: var(--link-colour);
    font-feature-settings: 'ss04';
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 1em;
    padding: var(--space-sm);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--text-color);
  }

  .arrow1 {
    margin-bottom: -0.3em;
    animation: fade-in-out 3s ease-out infinite;
  }

  .arrow2 {
    margin-top: -0.3em;
    animation: fade-in-out 3s ease-out infinite 0.5s;
  }

  @keyframes fade-in-out {
    0%, 100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }

</style>

<script>
  const GITHUB_USERNAME = "NeedsAdjustment";
  const DRIBBBLE_PROXY_URL = "https://spren-dribbleshotsgrabber.val.run/";

  function updateNum(category: string, value: number | string) {
    const links = document.querySelectorAll('h2 a.category');
    for (const link of links) {
      const num = link.querySelector('num');
      if (num && link.textContent?.trim().startsWith(category)) {
        num.textContent = String(value);
        break;
      }
    }
  }

  fetch(`https://api.github.com/users/${GITHUB_USERNAME}`)
    .then((r) => r.json())
    .then((data) => updateNum('coding', data.public_repos))
    .catch(() => {});

  fetch(DRIBBBLE_PROXY_URL)
    .then((r) => r.json())
    .then((data) => updateNum('design', data.shots_count))
    .catch(() => {});
</script>