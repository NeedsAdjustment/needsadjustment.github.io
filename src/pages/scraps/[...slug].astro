---
import Layout from '../../layouts/Layout.astro';
import HomeShell from '../../components/HomeShell.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allScraps = await getCollection('scraps');
  return [
    { params: { slug: undefined }, props: {} },
    ...allScraps.map((s) => ({
      params: { slug: s.data.slug },
      props: {},
    })),
  ];
}

const { slug } = Astro.params;
const allScraps = await getCollection('scraps');
const scrapCount = allScraps.length;
---

<Layout>
  <HomeShell scrapCount={scrapCount} initialSlug={slug} />
</Layout>

<script>
  window.__activeView = 'scraps';
</script>
